{
  "name": "@gewis/aurora-core",
  "version": "1.0.0",
  "description": "",
  "main": "src/index.ts",
  "exports": {
    ".": {
      "development": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./ports/data-source": {
      "development": "./src/ports/data-source.port.ts",
      "default": "./dist/src/ports/data-source.port.js"
    },
    "./ports/logger": {
      "development": "./src/ports/logger.port.ts",
      "default": "./dist/src/ports/logger.port.js"
    },
    "./ports/auth-strategy": {
      "development": "./src/ports/auth-strategy.port.ts",
      "default": "./dist/src/ports/auth-strategy.port.js"
    },
    "./helpers/security": {
      "development": "./src/helpers/security.ts",
      "default": "./dist/src/helpers/security.js"
    },
    "./helpers/security-groups": {
      "development": "./src/helpers/security-groups.ts",
      "default": "./dist/src/helpers/security-groups.js"
    },
    "./helpers/custom-error": {
      "development": "./src/helpers/custom-error.ts",
      "default": "./dist/src/helpers/custom-error.js"
    },
    "./helpers/transformers": {
      "development": "./src/helpers/transformers.ts",
      "default": "./dist/src/helpers/transformers.js"
    },
    "./modules/root/entities": {
      "development": "./src/modules/root/entities/index.ts",
      "default": "./dist/src/modules/root/entities/index.js"
    },
    "./modules/root/entities/base-entity": {
      "development": "./src/modules/root/entities/base-entity.ts",
      "default": "./dist/src/modules/root/entities/base-entity.js"
    },
    "./modules/auth/auth-user": {
      "development": "./src/modules/auth/auth-user.ts",
      "default": "./dist/src/modules/auth/auth-user.js"
    }
  },
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "concurrently 'nodemon' 'nodemon -x npx tsoa spec-and-routes'",
    "build": "tsoa spec-and-routes && tsc --project tsconfig.app.json",
    "typecheck": "tsc --noEmit --project tsconfig.app.json",
    "start": "node dist/src/index.js",
    "tsoa": "tsoa spec-and-routes",
    "lint": "eslint ./src --max-warnings=0",
    "lint-fix": "eslint ./src --fix",
    "format": "prettier --check ./src/",
    "format-fix": "prettier --write ./src/",
    "seed": "tsx src/seed/index.ts",
    "seed:gewis": "tsx src/seed/index.ts --gewis",
    "seed:hubble": "tsx src/seed/index.ts --hubble",
    "validate": "tsx src/validate.ts",
    "test": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fostertheweb/spotify-web-sdk": "^1.3.0",
    "@gewis/aurora-auth": "workspace:*",
    "@gewis/aurora-db-sqlite": "workspace:*",
    "@gewis/aurora-logger": "workspace:*",
    "@gewis/aurora-strategy-integration": "workspace:*",
    "@gewis/aurora-strategy-local": "workspace:*",
    "@sudosos/sudosos-client": "https://github.com/GEWIS/sudosos-client.git#commit=b1f2b656e1178626c0ab56b9aa4fc7a87b6fadcd",
    "async-lock": "^1.4.1",
    "axios": "1.13.3",
    "body-parser": "^2.2.2",
    "commander": "^14.0.2",
    "connect-typeorm": "^2.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "joi": "^18.0.2",
    "jwt-decode": "^4.0.0",
    "mime-types": "^3.0.2",
    "multer": "^2.0.2",
    "mysql2": "^3.16.1",
    "node-cron": "^4.2.1",
    "passport": "^0.7.0",
    "passport-custom": "^1.1.1",
    "qs": "^6.14.1",
    "socket.io": "^4.8.3",
    "sqlite3": "^5.1.7",
    "swagger-ui-express": "^5.0.1",
    "tsoa": "^7.0.0-alpha.0",
    "tsyringe": "^4.10.0",
    "typeorm": "^0.3.28",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@gewis/aurora-config": "1.0.0",
    "@tsoa/cli": "^7.0.0-alpha.0",
    "@tsoa/runtime": "^7.0.0-alpha.0",
    "@types/async-lock": "^1.4.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.2",
    "@types/mime-types": "^3.0.1",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.19.7",
    "@types/node-cron": "^3.0.11",
    "@types/passport": "^1.0.17",
    "@types/passport-strategy": "^0.2.38",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^11.0.0",
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "nodemon": "^3.1.11",
    "prettier": "^3.8.1",
    "reflect-metadata": "^0.2.2",
    "ts-node": "^10.9.2",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
